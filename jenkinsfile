pipeline{
    agent any
        tools
        {
            maven 'MAVEN_HOME'
        }
        stages
        {
            stage('WELCOME STAGE'){
                steps{
                    echo ' welcoome to pipeline'
                }
            }
            stage('Clean stage'){
                steps{
                    sh 'mvn clean'
                }
            }
            stage('Build Stage'){
                steps{
                    bat 'mvn install'
                }
            }
            stage('Build success'){
                steps{
                    echo 'Build Success'
                }
            }
        }
}
